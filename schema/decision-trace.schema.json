{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gokulrajaram/ProductSpec/schema/decision-trace.schema.json",
  "title": "Decision Trace",
  "type": "object",
  "required": [
    "decision_trace_format_version",
    "trace_id",
    "title",
    "created_at",
    "updated_at",
    "subject",
    "events"
  ],
  "properties": {
    "decision_trace_format_version": { "const": "0.1" },
    "trace_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "subject": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "enum": [
            "product_spec",
            "engineering_spec",
            "design",
            "implementation",
            "eval",
            "experiment",
            "incident",
            "other"
          ]
        },
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "product_spec_path": { "type": "string" },
        "product_spec_revision": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["event_id", "event_type", "occurred_at", "summary", "decision"],
        "properties": {
          "event_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$" },
          "event_type": {
            "enum": [
              "intent_decision",
              "scope_drift",
              "acceptance_criteria_drift",
              "ux_drift",
              "ai_eval_drift",
              "success_metric_review",
              "implementation_tradeoff",
              "spec_revision",
              "outcome_review"
            ]
          },
          "occurred_at": { "type": "string", "format": "date-time" },
          "summary": { "type": "string", "minLength": 1 },
          "source": {
            "type": "object",
            "properties": {
              "product_spec_revision": { "type": "integer", "minimum": 1 },
              "links": {
                "type": "array",
                "items": { "$ref": "#/$defs/link" }
              }
            },
            "additionalProperties": false
          },
          "drift": {
            "type": "object",
            "properties": {
              "spec_claim": { "type": "string" },
              "observed_reality": { "type": "string" }
            },
            "additionalProperties": false
          },
          "decision": {
            "type": "object",
            "required": ["outcome", "rationale"],
            "properties": {
              "outcome": {
                "enum": [
                  "update_spec",
                  "update_implementation",
                  "accept_tradeoff",
                  "reopen_work",
                  "record_learning",
                  "no_action"
                ]
              },
              "rationale": { "type": "string", "minLength": 1 },
              "approved_by": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          },
          "result": {
            "type": "object",
            "properties": {
              "new_product_spec_revision": { "type": "integer", "minimum": 1 },
              "linked_artifacts": {
                "type": "array",
                "items": { "$ref": "#/$defs/link" }
              },
              "learning": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "link": {
      "type": "object",
      "required": ["type", "url"],
      "properties": {
        "type": {
          "enum": [
            "product_spec",
            "engineering_spec",
            "github_issue",
            "github_pr",
            "jira_issue",
            "linear_issue",
            "figma",
            "eval_run",
            "analytics_snapshot",
            "experiment",
            "release",
            "other"
          ]
        },
        "url": { "type": "string", "minLength": 1 },
        "title": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
