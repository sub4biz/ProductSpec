{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gokulrajaram/ProductSpec/schema/product-spec.schema.json",
  "title": "Product Spec",
  "type": "object",
  "required": ["frontmatter", "sections"],
  "properties": {
    "frontmatter": {
      "type": "object",
      "required": ["spec_format_version", "title", "artifact_type", "author", "created_at", "updated_at"],
      "properties": {
        "spec_format_version": { "const": "0.1" },
        "title": { "type": "string", "minLength": 1 },
        "artifact_type": { "enum": ["hypothesis", "prd", "openspec_proposal"] },
        "spec_revision": { "type": "integer", "minimum": 1 },
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "linked_github_repo": { "type": "string" },
        "applies_to": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "required": ["path"],
                "properties": { "path": { "type": "string", "minLength": 1 } },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["component"],
                "properties": { "component": { "type": "string", "minLength": 1 } },
                "additionalProperties": false
              }
            ]
          }
        },
        "custom_sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "after"],
            "properties": {
              "id": { "type": "string", "pattern": "^custom-[a-z0-9]+(-[a-z0-9]+)*$" },
              "label": { "type": "string", "minLength": 1 },
              "after": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "tool_metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "array",
      "minItems": 5,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "problem" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "hypothesis" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "scope" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "acceptance_criteria" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "success_metrics" } },
            "required": ["id"]
          }
        }
      ],
      "items": {
        "type": "object",
        "required": ["id", "label", "content"],
        "properties": {
          "id": {
            "anyOf": [
              {
                "enum": [
                  "problem",
                  "hypothesis",
                  "scope",
                  "acceptance_criteria",
                  "success_metrics",
                  "user_experience",
                  "customer_truth",
                  "solution_alternatives",
                  "solution",
                  "strategic_positioning",
                  "adoption",
                  "pricing",
                  "risks",
                  "ai",
                  "open_questions",
                  "rollout",
                  "related_artifacts"
                ]
              },
              { "type": "string", "pattern": "^custom-[a-z0-9]+(-[a-z0-9]+)*$" }
            ]
          },
          "label": { "type": "string", "minLength": 1 },
          "content": { "type": "string" },
          "scope": {
            "type": "object",
            "required": ["in", "out", "cut"],
            "properties": {
              "in": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "out": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "cut": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "criterion"],
              "properties": {
                "id": { "type": "string", "pattern": "^AC-[1-9][0-9]*$" },
                "criterion": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "ai_evals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "type", "evaluator", "pass_threshold", "cases"],
              "properties": {
                "id": { "type": "string", "pattern": "^EVAL-[1-9][0-9]*$" },
                "type": {
                  "type": "string",
                  "enum": ["exact_match", "contains", "regex", "llm_judge", "human_review"]
                },
                "evaluator": {
                  "type": "string",
                  "enum": ["deterministic", "llm", "human"]
                },
                "pass_threshold": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
                "cases": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["input", "expected"],
                    "properties": {
                      "input": { "type": "string", "minLength": 1 },
                      "expected": { "type": "string", "minLength": 1 }
                    },
                    "additionalProperties": false
                  }
                },
                "checks": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            }
          },
          "success_metrics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "metric", "target", "window"],
              "properties": {
                "id": { "type": "string", "pattern": "^SM-[1-9][0-9]*$" },
                "metric": { "type": "string", "minLength": 1 },
                "target": { "type": "string", "minLength": 1 },
                "target_status": { "enum": ["committed", "provisional"] },
                "target_owner": { "type": "string", "minLength": 1 },
                "window": { "type": "string", "minLength": 1 }
              },
              "allOf": [
                {
                  "if": {
                    "properties": { "target_status": { "const": "provisional" } },
                    "required": ["target_status"]
                  },
                  "then": { "required": ["target_owner"] }
                }
              ],
              "additionalProperties": false
            }
          },
          "related_artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["type"],
              "allOf": [
                {
                  "if": { "properties": { "type": { "const": "product_spec" } }, "required": ["type"] },
                  "then": { "required": ["product_spec_path"], "not": { "required": ["url"] } },
                  "else": {
                    "required": ["url"],
                    "not": {
                      "anyOf": [
                        { "required": ["product_spec_path"] },
                        { "required": ["product_spec_revision"] },
                        { "required": ["relation"] }
                      ]
                    }
                  }
                }
              ],
              "properties": {
                "type": {
                  "enum": [
                    "github_issue",
                    "github_pr",
                    "jira_issue",
                    "linear_issue",
                    "figma",
                    "engineering_spec",
                    "eval_run",
                    "dashboard",
                    "analytics_snapshot",
                    "experiment",
                    "release",
                    "code",
                    "product_spec",
                    "other"
                  ]
                },
                "url": { "type": "string", "minLength": 1 },
                "title": { "type": "string" },
                "section_id": {
                  "anyOf": [
                    {
                      "enum": [
                        "problem",
                        "hypothesis",
                        "scope",
                        "acceptance_criteria",
                        "success_metrics",
                        "user_experience",
                        "customer_truth",
                        "solution_alternatives",
                        "solution",
                        "strategic_positioning",
                        "adoption",
                        "pricing",
                        "risks",
                        "ai",
                        "open_questions",
                        "rollout",
                        "related_artifacts"
                      ]
                    },
                    { "type": "string", "pattern": "^custom-[a-z0-9]+(-[a-z0-9]+)*$" }
                  ]
                },
                "item_id": { "type": "string", "pattern": "^(AC|SM|EVAL)-[1-9][0-9]*$" },
                "product_spec_path": { "type": "string", "minLength": 1 },
                "product_spec_revision": { "type": "integer", "minimum": 1 },
                "relation": { "enum": ["depends_on", "blocks", "supersedes", "relates_to"] }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
