{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gokulrajaram/ProductSpec/schema/product-spec.schema.json",
  "title": "Product Spec",
  "type": "object",
  "required": ["frontmatter", "sections"],
  "properties": {
    "frontmatter": {
      "type": "object",
      "required": ["spec_format_version", "title", "artifact_type", "author", "created_at", "updated_at"],
      "properties": {
        "spec_format_version": { "const": "0.1" },
        "title": { "type": "string", "minLength": 1 },
        "artifact_type": { "enum": ["hypothesis", "prd", "openspec_proposal"] },
        "spec_revision": { "type": "integer", "minimum": 1 },
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "linked_github_repo": { "type": "string" },
        "custom_sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "after"],
            "properties": {
              "id": { "type": "string", "pattern": "^custom-[a-z0-9]+(-[a-z0-9]+)*$" },
              "label": { "type": "string", "minLength": 1 },
              "after": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "tool_metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "sections": {
      "type": "array",
      "minItems": 5,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "problem" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "hypothesis" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "scope" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "acceptance_criteria" } },
            "required": ["id"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": { "id": { "const": "success_metrics" } },
            "required": ["id"]
          }
        }
      ],
      "items": {
        "type": "object",
        "required": ["id", "label", "content"],
        "properties": {
          "id": {
            "anyOf": [
              {
                "enum": [
                  "problem",
                  "hypothesis",
                  "scope",
                  "acceptance_criteria",
                  "success_metrics",
                  "user_experience",
                  "customer_truth",
                  "solution_alternatives",
                  "solution",
                  "strategic_positioning",
                  "adoption",
                  "pricing",
                  "risks",
                  "ai",
                  "open_questions",
                  "rollout"
                ]
              },
              { "type": "string", "pattern": "^custom-[a-z0-9]+(-[a-z0-9]+)*$" }
            ]
          },
          "label": { "type": "string", "minLength": 1 },
          "content": { "type": "string" },
          "scope": {
            "type": "object",
            "required": ["in", "out", "cut"],
            "properties": {
              "in": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "out": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "cut": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          },
          "ai_evals": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "input_set", "evaluator", "pass_threshold", "checks"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$" },
                "type": { "type": "string", "minLength": 1 },
                "input_set": { "type": "string", "minLength": 1 },
                "evaluator": { "type": "string", "minLength": 1 },
                "pass_threshold": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
                "checks": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                }
              },
              "additionalProperties": false
            }
          },
          "success_metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "metric", "target", "window", "segment", "source"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z0-9]+(_[a-z0-9]+)*$" },
                "metric": { "type": "string", "minLength": 1 },
                "target": { "type": "string", "minLength": 1 },
                "window": { "type": "string", "minLength": 1 },
                "segment": { "type": "string", "minLength": 1 },
                "source": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
